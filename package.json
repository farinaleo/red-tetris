{
  "name": "red-tetris",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "coverage": "jest --coverage",
    "start:server": "node server/src/index.js",
    "start:client": "webpack serve --mode development",
    "build:client": "webpack --mode production",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farinaleo/red-tetris.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/farinaleo/red-tetris/issues"
  },
  "homepage": "https://github.com/farinaleo/red-tetris#readme",
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.1",
    "coverage": "^0.4.1",
    "css-loader": "^7.1.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.12.0",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.5",
    "redux": "^5.0.1",
    "socket.io": "^4.8.1",
    "style-loader": "^4.0.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^30.2.0",
    "babel-loader": "^8.4.1",
    "babel-plugin-istanbul": "^7.0.1",
    "concurrently": "^9.2.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-fixed-jsdom": "^0.0.11",
    "nodemon": "^3.1.11",
    "redux-mock-store": "^1.5.5",
    "redux-thunk": "^3.1.0",
    "socket.io-client": "^4.8.1",
    "text-encoding": "^0.7.0",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "^socket.io-client$": "<rootDir>/__mocks__/socket.io-client.js"
    },
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "collectCoverageFrom": [
      "**/src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/store.js",
      "!src/types.js",
      "!**/node_modules/**",
      "!**/enums/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 50,
        "functions": 70,
        "lines": 70
      }
    },
    "moduleDirectories": [
      "node_modules",
      "client/src",
      "server/src"
    ]
  }
}
